---
import type { CollectionEntry } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import TagBadge from '../components/TagBadge.astro';
import Base from './Base.astro';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, tags } = Astro.props;
---

<Base title={`${title} - 不是很懂`} description={description}>
	<article class="mx-auto max-w-3xl px-4 py-10 sm:px-6">
		<!-- Article header -->
		<header class="mb-10 animate-fade-in-up">
			<!-- Back link -->
			<a href="/blog" class="mb-6 inline-flex items-center gap-1 text-sm text-zinc-500 transition-colors hover:text-primary-600 dark:text-zinc-400 dark:hover:text-primary-400">
				<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
					<path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
				</svg>
				返回博客
			</a>

			<h1 class="mb-5 text-3xl font-extrabold tracking-tight text-zinc-900 dark:text-zinc-50 sm:text-4xl lg:text-[2.5rem] lg:leading-tight">
				{title}
			</h1>
			<div class="flex flex-wrap items-center gap-3 text-sm text-zinc-500 dark:text-zinc-400">
				<div class="flex items-center gap-1.5">
					<img src="/images/blogAvatar.jpg" alt="moeyui" class="h-6 w-6 rounded-full object-cover" width="24" height="24" loading="lazy" />
					<span class="font-medium text-zinc-700 dark:text-zinc-300">moeyui</span>
				</div>
				<span class="text-zinc-300 dark:text-zinc-600">·</span>
				<div class="flex items-center gap-1.5">
					<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
					</svg>
					<FormattedDate date={pubDate} />
				</div>
				{updatedDate && (
					<>
						<span class="text-zinc-300 dark:text-zinc-600">·</span>
						<span class="italic">
							更新于 <FormattedDate date={updatedDate} />
						</span>
					</>
				)}
			</div>
			{tags && tags.length > 0 && (
				<div class="mt-5 flex flex-wrap gap-2">
					{tags.map((tag: string) => <TagBadge tag={tag} />)}
				</div>
			)}
		</header>

		<!-- Gradient divider -->
		<div class="mb-10 h-px bg-gradient-to-r from-transparent via-zinc-300 to-transparent dark:via-zinc-700"></div>

		<!-- Article content -->
		<div class="prose prose-zinc max-w-none dark:prose-invert prose-headings:scroll-mt-20 prose-headings:font-bold prose-a:text-primary-600 prose-a:no-underline prose-a:shadow-[inset_0_-2px_0_0_rgba(14,165,233,0.3)] hover:prose-a:shadow-[inset_0_-2px_0_0_rgba(14,165,233,0.6)] prose-pre:rounded-xl prose-pre:border prose-pre:border-zinc-200 prose-img:rounded-xl dark:prose-a:text-primary-400 dark:prose-a:shadow-[inset_0_-2px_0_0_rgba(56,189,248,0.3)] dark:hover:prose-a:shadow-[inset_0_-2px_0_0_rgba(56,189,248,0.6)] dark:prose-pre:border-zinc-800">
			<slot />
		</div>

		<!-- Article footer -->
		<div class="mt-16 rounded-2xl bg-gradient-to-r from-zinc-50 to-zinc-100/50 p-6 dark:from-zinc-900 dark:to-zinc-800/50">
			<div class="flex items-center gap-4">
				<img src="/images/blogAvatar.jpg" alt="moeyui" class="h-12 w-12 rounded-full object-cover ring-2 ring-white dark:ring-zinc-700" width="48" height="48" loading="lazy" />
				<div>
					<p class="font-semibold text-zinc-900 dark:text-zinc-100">moeyui</p>
					<p class="text-sm text-zinc-500 dark:text-zinc-400">不是很懂你们程序员</p>
				</div>
			</div>
		</div>
	</article>
</Base>
