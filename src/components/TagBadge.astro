---
interface Props {
	tag: string;
	count?: number;
	size?: 'sm' | 'md';
}

const { tag, count, size = 'sm' } = Astro.props;
const sizeClasses = {
	sm: 'px-2 py-0.5 text-xs',
	md: 'px-3 py-1 text-sm',
};
---

<a
	href={`/tags/${tag}`}
	class:list={[
		'inline-flex items-center gap-1 rounded-full border border-zinc-200 font-medium text-zinc-600 transition-colors hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700 dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-primary-700 dark:hover:bg-primary-950 dark:hover:text-primary-300',
		sizeClasses[size],
	]}
>
	<span>#{tag}</span>
	{count !== undefined && <span class="text-zinc-400 dark:text-zinc-500">({count})</span>}
</a>
