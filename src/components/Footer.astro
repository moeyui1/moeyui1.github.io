---
import { SITE_AUTHOR } from '../consts';
const year = new Date().getFullYear();
---

<footer class="relative overflow-hidden border-t border-zinc-200/60 dark:border-zinc-800/60">
	<!-- Subtle gradient bg -->
	<div class="absolute inset-0 -z-10 bg-gradient-to-t from-zinc-50 to-white dark:from-zinc-900 dark:to-zinc-950"></div>

	<div class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
		<div class="flex flex-col items-center gap-6">
			<!-- Top: avatar + tagline  -->
			<div class="flex items-center gap-3">
				<img
					src="/images/blogAvatar.jpg"
					alt={SITE_AUTHOR}
					class="h-10 w-10 rounded-full object-cover ring-2 ring-zinc-200 dark:ring-zinc-700"
					width="40"
					height="40"
					loading="lazy"
				/>
				<div>
					<p class="text-sm font-semibold text-zinc-800 dark:text-zinc-200">{SITE_AUTHOR}</p>
					<p class="text-xs text-zinc-500 dark:text-zinc-400">不是很懂你们程序员</p>
				</div>
			</div>

			<!-- Social links -->
			<div class="flex items-center gap-3">
				<a
					href="https://github.com/moeyui1"
					target="_blank"
					rel="noopener noreferrer"
					class="group rounded-full bg-zinc-100 p-2.5 text-zinc-500 transition-all hover:bg-zinc-900 hover:text-white dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-zinc-200 dark:hover:text-zinc-900"
					aria-label="GitHub"
				>
					<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
						<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"></path>
					</svg>
				</a>
				<a
					href="/rss.xml"
					class="group rounded-full bg-zinc-100 p-2.5 text-zinc-500 transition-all hover:bg-orange-500 hover:text-white dark:bg-zinc-800 dark:text-zinc-400 dark:hover:bg-orange-500 dark:hover:text-white"
					aria-label="RSS"
				>
					<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
						<path d="M6.18 15.64a2.18 2.18 0 012.18 2.18C8.36 19 7.38 20 6.18 20 5 20 4 19 4 17.82a2.18 2.18 0 012.18-2.18M4 4.44A15.56 15.56 0 0119.56 20h-2.83A12.73 12.73 0 004 7.27V4.44m0 5.66a9.9 9.9 0 019.9 9.9h-2.83A7.07 7.07 0 004 12.93V10.1z"></path>
					</svg>
				</a>
			</div>

			<!-- Copyright -->
			<p class="text-xs text-zinc-400 dark:text-zinc-500">
				&copy; {year} {SITE_AUTHOR} · Built with
				<a href="https://astro.build" target="_blank" rel="noopener noreferrer" class="text-zinc-500 transition-colors hover:text-primary-500 dark:text-zinc-400">Astro</a>
			</p>
		</div>
	</div>
</footer>
