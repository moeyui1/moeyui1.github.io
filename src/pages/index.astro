---
import { getCollection } from 'astro:content';
import PostCard from '../components/PostCard.astro';
import Base from '../layouts/Base.astro';
import { SITE_AUTHOR, PROJECTS } from '../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const recentPosts = posts.slice(0, 8);

// Collect tags for tech skills display
const tagMap = new Map<string, number>();
posts.forEach((p) => {
	const tags = p.data.tags;
	if (tags) {
		(Array.isArray(tags) ? tags : [tags]).forEach((t: string) => {
			tagMap.set(t, (tagMap.get(t) || 0) + 1);
		});
	}
});
const topTags = [...tagMap.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);
---

<Base>
	<!-- Hero Section: Tech-style with grid background -->
	<section class="tech-grid relative overflow-hidden border-b border-zinc-200/60 dark:border-zinc-800/60">
		<!-- Floating gradient orbs -->
		<div class="absolute inset-0 -z-10 overflow-hidden">
			<div class="absolute -left-20 top-10 h-[350px] w-[350px] rounded-full bg-primary-300/20 blur-3xl animate-float dark:bg-primary-700/10"></div>
			<div class="absolute -right-20 bottom-10 h-[300px] w-[300px] rounded-full bg-accent-400/15 blur-3xl animate-float dark:bg-accent-600/10" style="animation-delay: -3s;"></div>
			<div class="absolute left-1/2 top-1/3 h-[200px] w-[200px] rounded-full bg-emerald-200/20 blur-3xl animate-pulse-slow dark:bg-emerald-800/10"></div>
		</div>

		<div class="mx-auto max-w-4xl px-4 pb-16 pt-20 sm:px-6 sm:pb-20 sm:pt-28">
			<div class="flex flex-col items-center gap-10 sm:flex-row sm:items-start sm:gap-14">
				<!-- Avatar with animated ring -->
				<div class="animate-scale-in relative flex-shrink-0">
					<div class="absolute -inset-2 rounded-full bg-gradient-to-r from-primary-400 via-accent-400 to-primary-400 opacity-60 blur-lg animate-pulse-slow dark:opacity-30"></div>
					<div class="absolute -inset-[3px] rounded-full bg-gradient-to-r from-primary-500 via-accent-500 to-primary-500 dark:from-primary-400 dark:via-accent-400 dark:to-primary-400" style="background-size: 200% 200%; animation: gradientShift 3s ease infinite;"></div>
					<img
						src="/images/blogAvatar.jpg"
						alt={SITE_AUTHOR}
						class="relative h-28 w-28 rounded-full border-[3px] border-zinc-50 object-cover shadow-2xl dark:border-zinc-900 sm:h-36 sm:w-36"
						width="144"
						height="144"
						loading="eager"
					/>
				</div>

				<!-- Text content with typing effect -->
				<div class="text-center sm:text-left">
					<!-- Terminal-style greeting -->
					<div class="animate-fade-in-up mb-3 inline-flex items-center gap-2 rounded-full border border-primary-200 bg-primary-50/80 px-3 py-1 text-xs font-mono text-primary-700 backdrop-blur dark:border-primary-800 dark:bg-primary-950/50 dark:text-primary-300">
						<span class="h-1.5 w-1.5 rounded-full bg-primary-500 animate-pulse-slow"></span>
						~/moeyui.blog
					</div>

					<h1 class="animate-fade-in-up stagger-1 text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
						<span class="bg-gradient-to-r from-zinc-900 via-zinc-700 to-zinc-900 bg-clip-text text-transparent dark:from-zinc-100 dark:via-zinc-300 dark:to-zinc-100">不是很懂</span>
					</h1>

					<p class="animate-fade-in-up stagger-2 mt-4 text-lg leading-relaxed text-zinc-600 dark:text-zinc-400">
						不是很懂你们程序员 — 但热爱探索技术的一切。
					</p>

					<!-- Tech stack line with mono font -->
					<div class="animate-fade-in-up stagger-3 mt-3 font-mono text-sm text-zinc-500 dark:text-zinc-500">
						<span class="text-primary-600 dark:text-primary-400">const</span> focus <span class="text-primary-600 dark:text-primary-400">=</span> [<span class="text-amber-600 dark:text-amber-400">"AI"</span>, <span class="text-amber-600 dark:text-amber-400">"K8s"</span>, <span class="text-amber-600 dark:text-amber-400">"Cloud"</span>, <span class="text-amber-600 dark:text-amber-400">"AIGC"</span>]
					</div>

					<!-- Action buttons -->
					<div class="animate-fade-in-up stagger-4 mt-6 flex flex-wrap justify-center gap-3 sm:justify-start">
						<a href="/blog" class="group inline-flex items-center gap-2 rounded-lg bg-zinc-900 px-5 py-2.5 text-sm font-medium text-white shadow-lg shadow-zinc-900/20 transition-all hover:-translate-y-0.5 hover:shadow-xl hover:shadow-zinc-900/30 dark:bg-zinc-100 dark:text-zinc-900 dark:shadow-zinc-100/10 dark:hover:shadow-zinc-100/20">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" /></svg>
							阅读博客
						</a>
						<a href="https://github.com/moeyui1" target="_blank" rel="noopener noreferrer" class="group inline-flex items-center gap-2 rounded-lg border border-zinc-300 bg-white px-5 py-2.5 text-sm font-medium text-zinc-700 shadow-sm transition-all hover:-translate-y-0.5 hover:border-zinc-400 hover:shadow-md dark:border-zinc-700 dark:bg-zinc-900 dark:text-zinc-300 dark:hover:border-zinc-600">
							<svg class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"></path></svg>
							GitHub
						</a>
					</div>
				</div>
			</div>

			<!-- Stats bar: tech-style counters with icons -->
			<div class="animate-fade-in-up stagger-5 mt-12 grid grid-cols-3 gap-px overflow-hidden rounded-xl border border-zinc-200 bg-zinc-200 dark:border-zinc-800 dark:bg-zinc-800">
				<div class="flex flex-col items-center gap-1.5 bg-white px-4 py-5 dark:bg-zinc-900">
					<svg class="h-5 w-5 text-primary-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
					</svg>
					<span class="font-mono text-2xl font-bold text-zinc-900 dark:text-zinc-100">{posts.length}</span>
					<span class="text-xs text-zinc-500 dark:text-zinc-400">Posts</span>
				</div>
				<div class="flex flex-col items-center gap-1.5 bg-white px-4 py-5 dark:bg-zinc-900">
					<svg class="h-5 w-5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" />
						<path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" />
					</svg>
					<span class="font-mono text-2xl font-bold text-zinc-900 dark:text-zinc-100">{tagMap.size}</span>
					<span class="text-xs text-zinc-500 dark:text-zinc-400">Tags</span>
				</div>
				<div class="flex flex-col items-center gap-1.5 bg-white px-4 py-5 dark:bg-zinc-900">
					<svg class="h-5 w-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" />
					</svg>
					<span class="font-mono text-2xl font-bold text-zinc-900 dark:text-zinc-100">{new Date().getFullYear() - 2015}</span>
					<span class="text-xs text-zinc-500 dark:text-zinc-400">Years</span>
				</div>
			</div>

			<!-- Mobile: collapsible projects (between stats and tags) -->
			{PROJECTS.length > 0 && (
				<div class="animate-fade-in-up stagger-6 mt-5 lg:hidden">
					<button
						id="projects-toggle"
						type="button"
						class="flex w-full items-center justify-between rounded-xl border border-zinc-200 bg-white/80 px-4 py-3 text-left backdrop-blur transition-colors hover:bg-zinc-50 dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:bg-zinc-800/50"
					>
						<span class="flex items-center gap-2.5 text-sm font-semibold text-zinc-900 dark:text-zinc-100">
							<svg class="h-4 w-4 text-accent-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
							</svg>
							开源项目
						</span>
						<svg id="projects-chevron" class="h-4 w-4 text-zinc-400 transition-transform duration-200 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
						</svg>
					</button>
					<div id="projects-panel" class="hidden mt-3 space-y-3">
						{PROJECTS.map((project) => (
							<a
								href={project.url}
								target="_blank"
								rel="noopener noreferrer"
								class="group block overflow-hidden rounded-lg border border-zinc-200 bg-white transition-all hover:border-primary-300 hover:shadow-sm dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-primary-700"
							>
								{project.image && (
									<div class="border-b border-zinc-200 bg-gradient-to-br from-zinc-50 via-white to-primary-50/40 p-3 dark:border-zinc-800 dark:from-zinc-900 dark:via-zinc-900 dark:to-primary-950/30">
										<div class="max-h-52 overflow-hidden rounded-md border border-zinc-200/80 bg-white shadow-sm dark:border-zinc-700 dark:bg-zinc-950">
											<img
												src={project.image}
												alt={`${project.name} preview`}
												class:list={[
													'block w-full origin-top transition-transform duration-300 group-hover:scale-[1.03]',
													project.imageClass,
												]}
												loading="lazy"
												decoding="async"
											/>
										</div>
									</div>
								)}
								<div class="flex items-start gap-3 p-3.5">
									<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-md bg-zinc-100 text-base dark:bg-zinc-800">{project.icon}</span>
									<div class="flex-1 min-w-0">
										<div class="flex items-center gap-1.5">
											<span class="text-sm font-medium text-zinc-900 group-hover:text-primary-600 dark:text-zinc-100 dark:group-hover:text-primary-400">{project.name}</span>
											<svg class="h-3 w-3 text-zinc-400 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
										</div>
										<p class="mt-0.5 text-xs text-zinc-500 dark:text-zinc-400">{project.description}</p>
										{project.tags && project.tags.length > 0 && (
											<div class="mt-2 flex flex-wrap gap-1">
												{project.tags.map((tag: string) => (
													<span class="rounded border border-zinc-200 bg-zinc-50 px-1.5 py-0.5 font-mono text-[10px] text-zinc-500 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400">{tag}</span>
												))}
											</div>
										)}
									</div>
								</div>
							</a>
						))}
					</div>
				</div>
			)}
		</div>
	</section>

	<!-- Tech stack tags: horizontal scroll with animation -->
	{topTags.length > 0 && (
		<section class="border-b border-zinc-200/60 bg-white py-5 dark:border-zinc-800/60 dark:bg-zinc-900/50">
			<div class="mx-auto max-w-4xl px-4 sm:px-6">
				<div class="flex items-center gap-4 overflow-x-auto scrollbar-hide">
					<span class="flex-shrink-0 font-mono text-xs font-medium uppercase tracking-widest text-zinc-400 dark:text-zinc-500">Tech //</span>
					{topTags.map(([tag, count], i) => (
						<a
							href={`/tags/${tag}`}
							class:list={[
								'flex-shrink-0 animate-fade-in-up inline-flex items-center gap-1.5 rounded-md border bg-zinc-50 px-3 py-1.5 font-mono text-xs font-medium transition-all hover:-translate-y-0.5 hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-300 dark:hover:border-primary-700 dark:hover:bg-primary-950 dark:hover:text-primary-300',
								i % 2 === 0 ? 'border-zinc-200 text-zinc-600' : 'border-zinc-300 text-zinc-700 dark:border-zinc-600 dark:text-zinc-200',
							]}
							style={`animation-delay: ${i * 0.08}s`}
						>
							{tag}
							<span class="rounded bg-zinc-200 px-1 py-0.5 text-[10px] text-zinc-500 dark:bg-zinc-700 dark:text-zinc-400">{count}</span>
						</a>
					))}
				</div>
			</div>
		</section>
	)}

	<!-- Main content with sidebar -->
	<div class="mx-auto max-w-6xl px-4 pb-20 pt-10 sm:px-6">
		<div class="flex flex-col gap-10 lg:flex-row">
			<!-- Main: Recent posts -->
			<section class="flex-1 min-w-0">
				<div class="mb-8 flex items-center justify-between">
					<h2 class="flex items-center gap-3 text-xl font-semibold text-zinc-900 dark:text-zinc-100">
						<span class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-100 text-primary-600 dark:bg-primary-950 dark:text-primary-400">
							<svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
							</svg>
						</span>
						最新文章
					</h2>
					<a
						href="/blog"
						class="group inline-flex items-center gap-1.5 rounded-lg border border-zinc-200 px-3 py-1.5 text-sm font-medium text-zinc-600 transition-all hover:-translate-y-0.5 hover:border-primary-300 hover:bg-primary-50 hover:text-primary-700 hover:shadow-sm dark:border-zinc-700 dark:text-zinc-400 dark:hover:border-primary-800 dark:hover:bg-primary-950 dark:hover:text-primary-300"
					>
						查看全部
						<svg class="h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
							<path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
						</svg>
					</a>
				</div>
				<div class="grid gap-4">
					{recentPosts.map((post, i) => (
						<div class="animate-fade-in-up" style={`animation-delay: ${0.1 + i * 0.08}s`}>
							<PostCard post={post} featured={i === 0} />
						</div>
					))}
				</div>
			</section>

			<!-- Sidebar: Open Source Projects -->
			{PROJECTS.length > 0 && (
				<aside class="hidden w-72 flex-shrink-0 lg:block">
						<div class="sticky top-20">
							<h3 class="mb-4 flex items-center gap-2 text-xs font-semibold uppercase tracking-widest text-zinc-400 dark:text-zinc-500">
								<svg class="h-3.5 w-3.5 text-accent-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
									<path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5" />
								</svg>
								开源项目
							</h3>
							<div class="space-y-3">
								{PROJECTS.map((project, i) => (
									<a
										href={project.url}
										target="_blank"
										rel="noopener noreferrer"
										class="group animate-fade-in-up block overflow-hidden rounded-lg border border-zinc-200 bg-white transition-all hover:-translate-y-0.5 hover:border-primary-300 hover:shadow-md hover:shadow-primary-500/5 dark:border-zinc-800 dark:bg-zinc-900/50 dark:hover:border-primary-700"
										style={`animation-delay: ${0.3 + i * 0.1}s`}
									>
										{project.image && (
											<div class="border-b border-zinc-200 bg-gradient-to-br from-zinc-50 via-white to-primary-50/40 p-3 dark:border-zinc-800 dark:from-zinc-900 dark:via-zinc-900 dark:to-primary-950/30">
												<div class="max-h-52 overflow-hidden rounded-md border border-zinc-200/80 bg-white shadow-sm dark:border-zinc-700 dark:bg-zinc-950">
													<img
														src={project.image}
														alt={`${project.name} preview`}
														class:list={[
															'block w-full origin-top transition-transform duration-300 group-hover:scale-[1.03]',
															project.imageClass,
														]}
														loading="lazy"
														decoding="async"
													/>
												</div>
											</div>
										)}
										<div class="p-3.5">
											<div class="flex items-center gap-2.5">
												<span class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-md bg-zinc-100 text-base dark:bg-zinc-800">{project.icon}</span>
												<div class="flex-1 min-w-0">
													<div class="flex items-center gap-1.5">
														<span class="text-sm font-medium text-zinc-900 group-hover:text-primary-600 dark:text-zinc-100 dark:group-hover:text-primary-400">{project.name}</span>
														<svg class="h-3 w-3 flex-shrink-0 text-zinc-400 transition-transform group-hover:translate-x-0.5 dark:text-zinc-500" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" /></svg>
													</div>
												</div>
											</div>
											<p class="mt-2 text-xs leading-relaxed text-zinc-500 dark:text-zinc-400">{project.description}</p>
											{project.tags && project.tags.length > 0 && (
												<div class="mt-2.5 flex flex-wrap gap-1">
													{project.tags.map((tag: string) => (
														<span class="rounded border border-zinc-200 bg-zinc-50 px-1.5 py-0.5 font-mono text-[10px] text-zinc-500 dark:border-zinc-700 dark:bg-zinc-800 dark:text-zinc-400">{tag}</span>
													))}
												</div>
											)}
										</div>
									</a>
								))}
							</div>
					</div>
				</aside>
			)}
		</div>
	</div>
</Base>

<style>
	@keyframes gradientShift {
		0% { background-position: 0% 50%; }
		50% { background-position: 100% 50%; }
		100% { background-position: 0% 50%; }
	}
	.scrollbar-hide {
		-ms-overflow-style: none;
		scrollbar-width: none;
	}
	.scrollbar-hide::-webkit-scrollbar {
		display: none;
	}
</style>

<script>
	function setupProjectsToggle() {
		const btn = document.getElementById('projects-toggle');
		const panel = document.getElementById('projects-panel');
		const chevron = document.getElementById('projects-chevron');
		if (!btn || !panel || !chevron) return;
		btn.addEventListener('click', () => {
			const isHidden = panel.classList.contains('hidden');
			panel.classList.toggle('hidden');
			chevron.style.transform = isHidden ? 'rotate(180deg)' : '';
		});
	}
	setupProjectsToggle();
	document.addEventListener('astro:after-swap', setupProjectsToggle);
</script>
