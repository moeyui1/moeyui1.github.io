---
import { getCollection } from 'astro:content';
import PostCard from '../../components/PostCard.astro';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Base title="博客 - 不是很懂" description="所有博客文章">
	<section class="mx-auto max-w-4xl px-4 py-10 sm:px-6">
		<div class="mb-8">
			<h1 class="flex items-center gap-3 text-3xl font-bold tracking-tight text-zinc-900 dark:text-zinc-50">
				<span class="inline-block h-8 w-1.5 rounded-full bg-gradient-to-b from-primary-500 to-indigo-500"></span>
				所有文章
			</h1>
			<p class="mt-2 text-zinc-500 dark:text-zinc-400">共 {posts.length} 篇文章</p>
		</div>
		<div class="grid gap-4">
			{posts.map((post, i) => <PostCard post={post} featured={i === 0} />)}
		</div>
	</section>
</Base>
